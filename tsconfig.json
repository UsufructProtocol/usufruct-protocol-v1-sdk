{
  // Dev typecheck: both packages' src together, cross-package imports resolved
  // to SOURCE via paths (no build needed). `tsx` also reads these paths, so the
  // scripts resolve `@usufruct-protocol/*` to src. The per-package
  // `packages/*/tsconfig.json` are the build configs (emit dist via references).
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@usufruct-protocol/sdk": ["./packages/sdk/src/index.ts"],
      "@usufruct-protocol/sdk/*": ["./packages/sdk/src/*"],
      "@usufruct-protocol/sim": ["./packages/sim/src/index.ts"],
      "@usufruct-protocol/sim/*": ["./packages/sim/src/*"]
    }
  },
  "include": ["packages/sdk/src", "packages/sim/src"]
}
