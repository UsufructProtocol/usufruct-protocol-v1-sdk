{
  "name": "@usufruct-protocol/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Usufruct protocol on Sui",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "codegen": "sui-ts-codegen generate",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "e2e": "tsx scripts/e2e-testnet.ts",
    "keystone": "tsx scripts/keystone-slice.ts"
  },
  "keywords": [
    "sui",
    "usufruct",
    "sdk"
  ],
  "author": "Antonio Jiménez <build@0xkurious.xyz>",
  "license": "Apache-2.0",
  "type": "module",
  "devDependencies": {
    "@mysten/codegen": "^0.10.6",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0"
  }
}
